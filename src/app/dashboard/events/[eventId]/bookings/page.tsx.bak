"use client";

import { Button } from "@/components/ui/button";
import { events, type Booking } from "@/data/events";
import {
  AlertTriangle,
  ArrowDown,
  ArrowUp,
  CalendarCheck,
  CheckCircle2,
  ChevronDown,
  ChevronsUpDown,
  Clock,
  HourglassIcon,
  Lock,
  LockOpen,
  TrendingUp,
  XCircle,
} from "lucide-react";
import { notFound } from "next/navigation";
import { use, useState } from "react";

type BookingStatus = "pending" | "accepted" | "denied";
type FilterStatus = "all" | BookingStatus;
type SortKey = "name" | "business" | "guests" | "status";
type SortDir = "asc" | "desc";

const statusConfig: Record<
  BookingStatus,
  { label: string; pill: string; icon: React.ElementType }
> = {
  pending: {
    label: "Väntar",
    pill: "bg-amber-50 text-amber-600 border border-amber-200",
    icon: HourglassIcon,
  },
  accepted: {
    label: "Accepterad",
    pill: "bg-emerald-50 text-emerald-700 border border-emerald-200",
    icon: CheckCircle2,
  },
  denied: { label: "Nekad", pill: "bg-red-50 text-red-500 border border-red-200", icon: XCircle },
};

const FILTER_OPTIONS: { value: FilterStatus; label: string }[] = [
  { value: "all", label: "Alla" },
  { value: "pending", label: "Väntar" },
  { value: "accepted", label: "Accepterade" },
  { value: "denied", label: "Nekade" },
];

export default function BookingsPage({ params }: { params: Promise<{ eventId: string }> }) {
  const { eventId } = use(params);
  const event = events.find((e) => e.id === eventId);
  if (!event) notFound();

  const [bookings, setBookings] = useState<Booking[]>(event.bookings);
  const [filter, setFilter] = useState<FilterStatus>("all");
  const [expanded, setExpanded] = useState<Record<string, boolean>>({});
  const [closedSlots, setClosedSlots] = useState<Record<string, boolean>>({});
  const [scrolledToBottom, setScrolledToBottom] = useState<Record<string, boolean>>({});
  const [showClosed, setShowClosed] = useState(true);
  const [sortKey, setSortKey] = useState<Record<string, SortKey>>({});
  const [sortDir, setSortDir] = useState<Record<string, SortDir>>({});

  const handleSort = (key: string, col: SortKey) => {
    setSortKey((prev) => ({ ...prev, [key]: col }));
    setSortDir((prev) => ({
      ...prev,
      [key]: prev[key] === "asc" && sortKey[key] === col ? "desc" : "asc",
    }));
  };

  const sortBookings = (rows: Booking[], key: string) => {
    const col = sortKey[key];
    const dir = sortDir[key] ?? "asc";
    if (!col) return rows;
    return [...rows].sort((a, b) => {
      const av =
        col === "guests"
          ? a.guests
          : col === "status"
            ? a.status
            : col === "name"
              ? a.name
              : a.business;
      const bv =
        col === "guests"
          ? b.guests
          : col === "status"
            ? b.status
            : col === "name"
              ? b.name
              : b.business;
      if (av < bv) return dir === "asc" ? -1 : 1;
      if (av > bv) return dir === "asc" ? 1 : -1;
      return 0;
    });
  };

  const slotKey = (date: string, time: string) => `${date}|${time}`;

  const updateStatus = (id: string, status: BookingStatus) =>
    setBookings((prev) => prev.map((b) => (b.id === id ? { ...b, status } : b)));

  const toggleExpanded = (key: string) => setExpanded((prev) => ({ ...prev, [key]: !prev[key] }));

  const toggleClosedSlot = (date: string, time: string) =>
    setClosedSlots((prev) => ({ ...prev, [slotKey(date, time)]: !prev[slotKey(date, time)] }));

  const isDayClosed = (date: string, times: string[]) =>
    times.length > 0 && times.every((t) => closedSlots[slotKey(date, t)]);

  const totalPending = bookings.filter((b) => b.status === "pending").length;
  const totalAccepted = bookings.filter((b) => b.status === "accepted").length;
  const totalDenied = bookings.filter((b) => b.status === "denied").length;
  const totalGuests = bookings
    .filter((b) => b.status === "accepted")
    .reduce((s, b) => s + b.guests, 0);
  const totalDays = new Set(bookings.map((b) => b.date)).size;
  const avgPerDay = totalDays > 0 ? Math.round(totalGuests / totalDays) : 0;

  // Group by date
  const byDate = bookings.reduce<Record<string, Booking[]>>((acc, b) => {
    acc[b.date] = acc[b.date] ?? [];
    acc[b.date].push(b);
    return acc;
  }, {});

  const sortedDates = Object.keys(byDate)
    .sort()
    .filter((date) => filter === "all" || byDate[date].some((b) => b.status === filter))
    .filter((date) => {
      if (showClosed) return true;
      const timeKeys = [...new Set(byDate[date].map((b) => b.time))].sort();
      return !isDayClosed(date, timeKeys);
    });

  return (
    <div className="w-full">
      {/* Page title */}
      <div className="mb-8">
        <h1 className="text-2xl font-semibold tracking-tight">
          {event.name} {event.year}
        </h1>
        <p className="text-sm text-muted-foreground mt-1">
          Kapacitet per tillfälle: <strong>{event.capacity} gäster</strong>
        </p>
      </div>

      {/* Stats */}
      <div className="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-8">
        {[
          {
            label: "Väntar",
            value: totalPending,
            sub: "förfrågningar",
            color: "",
            icon: HourglassIcon,
          },
          {
            label: "Accepterade",
            value: totalAccepted,
            sub: "bokningar",
            color: "text-emerald-600",
            icon: CheckCircle2,
          },
          {
            label: "Nekade",
            value: totalDenied,
            sub: "bokningar",
            color: "text-red-500",
            icon: XCircle,
          },
          { label: "Bekr. gäster", value: totalGuests, sub: "totalt", color: "", icon: TrendingUp },
          { label: "Snitt / dag", value: avgPerDay, sub: "gäster", color: "", icon: CalendarCheck },
        ].map(({ label, value, sub, color, icon: Icon }) => (
          <div
            key={label}
            className="bg-white rounded-2xl border border-border p-4 flex flex-col gap-3"
          >
            <div className="flex items-center justify-between">
              <p className="text-xs font-medium text-muted-foreground uppercase tracking-wider">
                {label}
              </p>
              <div className="w-7 h-7 rounded-lg bg-muted/60 flex items-center justify-center">
                <Icon className="w-3.5 h-3.5 text-muted-foreground" />
              </div>
            </div>
            <div>
              <p className={`text-3xl font-semibold tabular-nums ${color}`}>{value}</p>
              <p className="text-xs text-muted-foreground mt-0.5">{sub}</p>
            </div>
          </div>
        ))}
      </div>

      {/* Filter bar */}
      <div className="flex items-center gap-3 mb-5">
        <div className="flex items-center gap-1.5 bg-white border border-border rounded-xl p-1 w-fit">
          {FILTER_OPTIONS.map((opt) => {
            const count =
              opt.value === "pending"
                ? totalPending
                : opt.value === "accepted"
                  ? totalAccepted
                  : opt.value === "denied"
                    ? totalDenied
                    : null;
            return (
              <button
                key={opt.value}
                onClick={() => setFilter(opt.value)}
                className={`cursor-pointer flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium transition-all ${
                  filter === opt.value
                    ? "bg-foreground text-background shadow-sm"
                    : "text-muted-foreground hover:text-foreground"
                }`}
              >
                {opt.label}
                {count !== null && (
                  <span
                    className={`tabular-nums text-[10px] rounded-full px-1.5 py-0.5 leading-none font-semibold ${
                      filter === opt.value
                        ? "bg-white/20 text-background"
                        : "bg-muted text-muted-foreground"
                    }`}
                  >
                    {count}
                  </span>
                )}
              </button>
            );
          })}
        </div>
        {(() => {
          const allKeys = sortedDates.flatMap((date) =>
            [...new Set(byDate[date].map((b) => b.time))].sort().map((time) => slotKey(date, time)),
          );
          const anyExpanded = allKeys.some((k) => expanded[k]);
          return (
            <button
              onClick={() => {
                const next = !anyExpanded;
                setExpanded(Object.fromEntries(allKeys.map((k) => [k, next])));
              }}
              className="cursor-pointer flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-muted-foreground hover:text-foreground transition-colors whitespace-nowrap"
            >
              {anyExpanded ? (
                <>
                  <ChevronDown className="w-3.5 h-3.5 rotate-180" /> Fäll ihop alla
                </>
              ) : (
                <>
                  <ChevronDown className="w-3.5 h-3.5" /> Expandera alla
                </>
              )}
            </button>
          );
        })()}
        <button
          onClick={() => setShowClosed((prev) => !prev)}
          className={`cursor-pointer flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium transition-all ${
            !showClosed
              ? "bg-foreground text-background shadow-sm"
              : "text-muted-foreground hover:text-foreground"
          }`}
        >
          <Lock className="w-3 h-3" />
          {showClosed ? "Göm stängda dagar" : "Visa stängda dagar"}
        </button>
      </div>

      {/* Date groups */}
      <div className="flex flex-col gap-6">
        {sortedDates.map((date) => {
          const allDay = byDate[date];
          const timeKeys = [...new Set(allDay.map((b) => b.time))].sort();
          const isClosed = isDayClosed(date, timeKeys);

          const dayDate = new Date(date);
          const weekday = dayDate.toLocaleDateString("sv-SE", { weekday: "long" });
          const dayNum = dayDate.toLocaleDateString("sv-SE", { day: "numeric", month: "long" });

          return (
            <div key={date}>
              {/* Day heading */}
              <div
                className={`flex items-stretch rounded-2xl border overflow-hidden mb-2 ${isClosed ? "border-red-200" : "border-border"}`}
              >
                {/* Date block */}
                <div
                  className={`shrink-0 w-20 flex flex-col items-center justify-center py-3 border-r ${isClosed ? "border-red-200 bg-red-100/40" : "border-border bg-white"}`}
                >
                  <span className="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground">
                    {weekday.slice(0, 3)}
                  </span>
                  <span className="text-2xl font-bold tabular-nums leading-tight">
                    {dayDate.getDate()}
                  </span>
                  <span className="text-[10px] text-muted-foreground capitalize">
                    {dayDate.toLocaleDateString("sv-SE", { month: "short" })}
                  </span>
                </div>
                {/* Info */}
                <div
                  className={`flex-1 flex items-center justify-between px-4 py-3 ${isClosed ? "bg-red-50/30" : "bg-white"}`}
                >
                  <div>
                    <div className="flex items-center gap-2 mb-1">
                      <h2 className="text-sm font-semibold capitalize">
                        {weekday} {dayNum}
                      </h2>
                      {isClosed && (
                        <span className="inline-flex items-center gap-1 rounded-full bg-red-100 text-red-600 text-[10px] font-semibold px-2 py-0.5 border border-red-200">
                          <Lock className="w-2.5 h-2.5" /> Stängd dag
                        </span>
                      )}
                    </div>
                    <div className="flex flex-wrap gap-x-3 gap-y-0.5">
                      {(() => {
                        const dayAccepted = allDay
                          .filter((b) => b.status === "accepted")
                          .reduce((s, b) => s + b.guests, 0);
                        const dayPending = allDay.filter((b) => b.status === "pending").length;
                        const dayCapacity = timeKeys.length * event.capacity;
                        return (
                          <>
                            <span className="text-xs text-muted-foreground tabular-nums">
                              <span className="font-medium text-foreground">{dayAccepted}</span> /{" "}
                              {dayCapacity} gäster bokade
                            </span>
                            {dayPending > 0 && (
                              <span className="text-xs text-amber-600 flex items-center gap-1">
                                <HourglassIcon className="w-3 h-3" />
                                {dayPending} väntar svar
                              </span>
                            )}
                          </>
                        );
                      })()}
                    </div>
                  </div>
                  <div className="flex items-center gap-2">
                    {(() => {
                      const dayKeys = timeKeys.map((t) => slotKey(date, t));
                      const anyDayExpanded = dayKeys.some((k) => expanded[k]);
                      return (
                        <button
                          onClick={() => {
                            const next = !anyDayExpanded;
                            setExpanded((prev) => ({
                              ...prev,
                              ...Object.fromEntries(dayKeys.map((k) => [k, next])),
                            }));
                          }}
                          className="cursor-pointer inline-flex items-center gap-1.5 rounded-lg border border-border px-2.5 py-1 text-xs font-medium text-muted-foreground hover:text-foreground bg-white transition-colors"
                        >
                          <ChevronDown
                            className={`w-3 h-3 transition-transform duration-150 ${anyDayExpanded ? "rotate-180" : ""}`}
                          />
                          {anyDayExpanded ? "Fäll ihop" : "Expandera"}
                        </button>
                      );
                    })()}
                    {timeKeys.length > 1 && (
                      <button
                        onClick={() => {
                          const allClosed = isDayClosed(date, timeKeys);
                          timeKeys.forEach((t) =>
                            setClosedSlots((prev) => ({ ...prev, [slotKey(date, t)]: !allClosed })),
                          );
                        }}
                        className={`cursor-pointer inline-flex items-center gap-1.5 rounded-lg border px-2.5 py-1 text-xs font-medium transition-colors ${
                          isClosed
                            ? "border-emerald-200 text-emerald-700 hover:bg-emerald-50 bg-white"
                            : "border-border text-muted-foreground hover:border-red-200 hover:text-red-600 hover:bg-red-50"
                        }`}
                      >
                        {isClosed ? (
                          <>
                            <LockOpen className="w-3 h-3" /> Öppna dag
                          </>
                        ) : (
                          <>
                            <Lock className="w-3 h-3" /> Stäng dag
                          </>
                        )}
                      </button>
                    )}
                  </div>
                </div>
              </div>

              {/* Slot accordions */}
              <div className="flex flex-col gap-2">
                {timeKeys.map((time) => {
                  const key = slotKey(date, time);
                  const isOpen = !!expanded[key];
                  const isSlotClosed = !!closedSlots[key];
                  const allTimeBookings = allDay.filter((b) => b.time === time);
                  const visibleBookings =
                    filter === "all"
                      ? allTimeBookings
                      : allTimeBookings.filter((b) => b.status === filter);
                  const timeAccepted = allTimeBookings
                    .filter((b) => b.status === "accepted")
                    .reduce((s, b) => s + b.guests, 0);
                  const timePending = allTimeBookings
                    .filter((b) => b.status === "pending")
                    .reduce((s, b) => s + b.guests, 0);
                  const timeRemaining = Math.max(event.capacity - timeAccepted, 0);
                  const timeNearFull = timeAccepted / event.capacity >= 0.8;
                  const timeFull = isSlotClosed || timeAccepted >= event.capacity;
                  const fillPct = Math.min((timeAccepted / event.capacity) * 100, 100);
                  const pendPct = Math.min((timePending / event.capacity) * 100, 100 - fillPct);
                  const pendingCount = allTimeBookings.filter((b) => b.status === "pending").length;

                  // Hide slot if filter active and no matching bookings
                  if (filter !== "all" && visibleBookings.length === 0) return null;

                  return (
                    <div
                      key={key}
                      className={`rounded-2xl border overflow-hidden transition-all ${isSlotClosed ? "border-red-200 bg-red-50/20" : "border-border bg-white"}`}
                    >
                      {/* Slot header — always visible, click to expand */}
                      <div className="flex items-center gap-4 px-5 py-3.5">
                        {/* Clock icon */}
                        <Clock
                          className={`shrink-0 w-4 h-4 ${isSlotClosed ? "text-red-400" : "text-muted-foreground"}`}
                        />

                        {/* Time + status info */}
                        <button
                          onClick={() => toggleExpanded(key)}
                          className="cursor-pointer flex-1 flex items-center gap-4 text-left min-w-0"
                        >
                          <span className="text-base font-semibold tabular-nums shrink-0">
                            {time}
                          </span>

                          <div className="flex items-center gap-3 min-w-0 flex-1">
                            {isSlotClosed && (
                              <span className="inline-flex items-center gap-1 rounded-full bg-red-100 text-red-600 text-[10px] font-semibold px-2 py-0.5 border border-red-200">
                                <Lock className="w-2.5 h-2.5" /> Stängd
                              </span>
                            )}
                            {/* Capacity bar */}
                            <div className="w-24 shrink-0 h-1.5 bg-muted rounded-full overflow-hidden">
                              <div className="h-full flex">
                                <div
                                  className={`h-full transition-all duration-500 ${isSlotClosed ? "bg-red-300" : timeFull ? "bg-red-500" : timeNearFull ? "bg-amber-400" : "bg-emerald-500"}`}
                                  style={{ width: `${fillPct}%` }}
                                />
                                {!isSlotClosed && (
                                  <div
                                    className="h-full bg-amber-200 transition-all duration-500"
                                    style={{ width: `${pendPct}%` }}
                                  />
                                )}
                              </div>
                            </div>
                            <span
                              className={`text-xs tabular-nums font-medium shrink-0 ${isSlotClosed ? "text-muted-foreground" : timeFull ? "text-red-600" : timeNearFull ? "text-amber-600" : "text-muted-foreground"}`}
                            >
                              {isSlotClosed
                                ? `${timeAccepted} / ${event.capacity} bokade`
                                : timeFull
                                  ? "Fullbelagt"
                                  : `${timeRemaining} av ${event.capacity} kvar`}
                            </span>
                            {!isSlotClosed && pendingCount > 0 && (
                              <span className="hidden sm:inline-flex items-center gap-1 text-xs text-amber-500 shrink-0">
                                <HourglassIcon className="w-3 h-3" />
                                {pendingCount} väntar
                              </span>
                            )}
                          </div>
                        </button>

                        {/* Right: booking count + stäng + chevron */}
                        <div className="flex items-center gap-2 shrink-0">
                          <span className="text-xs text-muted-foreground tabular-nums hidden sm:block">
                            {allTimeBookings.length} bokning
                            {allTimeBookings.length !== 1 ? "ar" : ""}
                          </span>
                          <button
                            onClick={() => toggleClosedSlot(date, time)}
                            className={`cursor-pointer inline-flex items-center gap-1.5 rounded-lg border px-2 py-1 text-xs font-medium transition-colors ${
                              isSlotClosed
                                ? "border-emerald-200 text-emerald-700 hover:bg-emerald-50 bg-white"
                                : "border-border text-muted-foreground hover:border-red-200 hover:text-red-600 hover:bg-red-50"
                            }`}
                          >
                            {isSlotClosed ? (
                              <>
                                <LockOpen className="w-3 h-3" />
                                <span className="hidden sm:inline"> Öppna</span>
                              </>
                            ) : (
                              <>
                                <Lock className="w-3 h-3" />
                                <span className="hidden sm:inline"> Stäng</span>
                              </>
                            )}
                          </button>
                          <button
                            onClick={() => toggleExpanded(key)}
                            className="cursor-pointer p-1 rounded-md hover:bg-muted transition-colors"
                          >
                            <ChevronDown
                              className={`w-4 h-4 text-muted-foreground transition-transform duration-200 ease-in-out ${isOpen ? "rotate-180" : ""}`}
                            />
                          </button>
                        </div>
                      </div>

                      {/* Expanded: booking table */}
                      <div
                        className={`grid transition-all duration-200 ease-in-out ${isOpen ? "grid-rows-[1fr]" : "grid-rows-[0fr]"}`}
                      >
                        <div className="overflow-hidden">
                          <div className="border-t border-border relative">
                            <div
                              className="overflow-y-auto max-h-[504px]"
                              onScroll={(e) => {
                                const el = e.currentTarget;
                                const atBottom =
                                  el.scrollHeight - el.scrollTop <= el.clientHeight + 2;
                                setScrolledToBottom((prev) => ({ ...prev, [key]: atBottom }));
                              }}
                            >
                              <table className="w-full text-sm table-fixed">
                                <colgroup>
                                  <col className="w-[20%]" />
                                  <col className="w-[20%]" />
                                  <col className="w-[15%]" />
                                  <col className="w-[8%]" />
                                  <col className="w-[15%]" />
                                  <col className="w-[22%]" />
                                </colgroup>
                                <thead className="sticky top-0 z-10">
                                  <tr className="bg-[#f5f5f7] shadow-[0_1px_0_0_#e5e7eb]">
                                    {(
                                      [
                                        { label: "Namn", col: "name" as SortKey, hide: false },
                                        {
                                          label: "Verksamhet",
                                          col: "business" as SortKey,
                                          hide: false,
                                        },
                                        { label: "E-post", col: null, hide: true },
                                        { label: "Gäster", col: "guests" as SortKey, hide: false },
                                        { label: "Status", col: "status" as SortKey, hide: false },
                                        { label: "Åtgärder", col: null, hide: false },
                                      ] as { label: string; col: SortKey | null; hide: boolean }[]
                                    ).map(({ label, col, hide }) => {
                                      const active = col && sortKey[key] === col;
                                      const Icon = active
                                        ? sortDir[key] === "asc"
                                          ? ArrowUp
                                          : ArrowDown
                                        : ChevronsUpDown;
                                      return (
                                        <th
                                          key={label}
                                          className={`text-left px-5 py-2 text-[10px] font-semibold uppercase tracking-wide text-muted-foreground ${hide ? "hidden lg:table-cell" : ""} ${col ? "cursor-pointer select-none hover:text-foreground" : ""}`}
                                          onClick={col ? () => handleSort(key, col) : undefined}
                                        >
                                          <div className="flex items-center gap-1">
                                            {label}
                                            {col && (
                                              <Icon
                                                className={`w-3 h-3 ${active ? "text-foreground" : "text-muted-foreground/40"}`}
                                              />
                                            )}
                                          </div>
                                        </th>
                                      );
                                    })}
                                  </tr>
                                </thead>
                                <tbody className="divide-y divide-border">
                                  {visibleBookings.length > 0 ? (
                                    sortBookings(visibleBookings, key).map((booking) => {
                                      const {
                                        label,
                                        pill,
                                        icon: StatusIcon,
                                      } = statusConfig[booking.status as BookingStatus];
                                      const wouldExceed =
                                        booking.status === "pending" &&
                                        timeAccepted + booking.guests > event.capacity;
                                      return (
                                        <tr
                                          key={booking.id}
                                          className="hover:bg-muted/10 transition-colors"
                                        >
                                          <td className="px-5 py-3 min-w-0">
                                            <p className="font-medium truncate">{booking.name}</p>
                                            <p className="text-xs text-muted-foreground truncate">
                                              {booking.phone}
                                            </p>
                                          </td>
                                          <td className="px-5 py-3 min-w-0">
                                            <p className="text-sm text-muted-foreground truncate">
                                              {booking.business}
                                            </p>
                                          </td>
                                          <td className="px-5 py-3 min-w-0 hidden lg:table-cell">
                                            <p className="text-xs text-muted-foreground truncate">
                                              {booking.email}
                                            </p>
                                          </td>
                                          <td className="px-5 py-3">
                                            <div className="flex items-center gap-1.5">
                                              <span className="font-semibold tabular-nums">
                                                {booking.guests}
                                              </span>
                                              {wouldExceed && (
                                                <AlertTriangle className="w-3.5 h-3.5 text-red-500 shrink-0" />
                                              )}
                                            </div>
                                          </td>
                                          <td className="px-5 py-3">
                                            <span
                                              className={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium ${pill}`}
                                            >
                                              <StatusIcon className="w-3 h-3 shrink-0" />
                                              {label}
                                            </span>
                                          </td>
                                          <td className="px-5 py-3">
                                            <div className="flex items-center gap-2">
                                              {booking.status !== "accepted" && (
                                                <Button
                                                  size="sm"
                                                  variant="outline"
                                                  className={`h-7 text-xs font-medium transition-all ${wouldExceed ? "border-amber-200 text-amber-700 hover:bg-amber-50" : "border-emerald-200 text-emerald-700 hover:bg-emerald-50 hover:border-emerald-300"}`}
                                                  onClick={(e) => {
                                                    e.stopPropagation();
                                                    updateStatus(booking.id, "accepted");
                                                  }}
                                                >
                                                  <CheckCircle2 className="w-3 h-3 mr-1" />
                                                  Acceptera
                                                </Button>
                                              )}
                                              {booking.status !== "denied" && (
                                                <Button
                                                  size="sm"
                                                  variant="outline"
                                                  className="h-7 text-xs font-medium border-border text-muted-foreground hover:border-red-200 hover:text-red-600 hover:bg-red-50 transition-all"
                                                  onClick={(e) => {
                                                    e.stopPropagation();
                                                    updateStatus(booking.id, "denied");
                                                  }}
                                                >
                                                  <XCircle className="w-3 h-3 mr-1" />
                                                  {booking.status === "accepted"
                                                    ? "Avboka"
                                                    : "Neka"}
                                                </Button>
                                              )}
                                            </div>
                                          </td>
                                        </tr>
                                      );
                                    })
                                  ) : (
                                    <tr>
                                      <td
                                        colSpan={6}
                                        className="px-5 py-4 text-xs text-muted-foreground italic"
                                      >
                                        Inga bokningar matchar filtret.
                                      </td>
                                    </tr>
                                  )}
                                </tbody>
                              </table>
                            </div>
                            {visibleBookings.length > 9 && !scrolledToBottom[key] && (
                              <div className="pointer-events-none absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent" />
                            )}
                          </div>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}
